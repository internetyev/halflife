# halflife — environment variable template
#
# Copy to `.env.local` before running `next dev`. `.env.local` is gitignored.
# Never commit a real key. The routine never writes secrets — these are
# populated by the human operator, locally and on Vercel.

# ---------------------------------------------------------------------------
# Anthropic — required. Used by app/api/analyze for the Claude tool-use call.
# Use a project-scoped key, not a personal one. Sonnet 4.6 is the default
# model (see PLAN.md). Prompt caching is enabled in code; no flag needed here.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Vercel KV — required for the role-result cache (30-day TTL keyed by slug).
# All four are auto-injected when you link a KV store via `vercel link`.
# Locally, copy them out of the Vercel dashboard for the linked project.
# ---------------------------------------------------------------------------
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ---------------------------------------------------------------------------
# Plausible analytics — optional. Set to the domain registered in Plausible
# (e.g. `halflife.work`). When unset, the analytics snippet is a no-op.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ---------------------------------------------------------------------------
# Public site URL — used for canonical links, OG image absolute URLs, and
# sitemap generation. Set per environment (preview, production).
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Plunk — optional, email capture (L5.4). Secret API key from the Plunk
# project (Settings → API keys, the `sk_…` secret key, NOT the public one).
# When unset, /api/subscribe returns 503 and the capture form shows an
# "opens at launch" note — no network call. Set during the human-gated
# L5.4b. ADR: DECISIONS.md D-034.
# ---------------------------------------------------------------------------
PLUNK_API_KEY=
