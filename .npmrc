# Repo-root npm config — the package-manager-layer companion to .nvmrc (L5.27)
# and .editorconfig/.gitattributes (L5.24/L5.26). Sets two policies the rest of
# the routine has decided implicitly but never pinned at the npm-tool level:
#
# 1. engine-strict=true — refuse install/run on a Node version outside
#    package.json's "engines.node": ">=20.0.0" floor (the floor stays at 20,
#    .nvmrc pins the active line at 22 — different purposes, both still hold).
#    Without this flag npm only WARNS on engine mismatch; with it, `npm install`
#    hard-fails on Node 18, surfacing the version drift before a confusing
#    next/react peer-dep error fires.
#
# 2. package-lock=false — match the existing .gitignore posture ("installs are
#    a human step ... the routine may eventually generate lockfiles and the
#    human commits them by hand") and the CI workflow's deliberate
#    `npm install --no-fund --no-audit` (not `npm ci`, per L5.21/D-051) by
#    refusing to write a package-lock.json on every developer install. The day
#    the human commits a lockfile by hand, flipping this back to true (or
#    deleting the line) is a one-line edit; until then, no contributor's local
#    install can drop a stray lockfile into the working tree.
engine-strict=true
package-lock=false
